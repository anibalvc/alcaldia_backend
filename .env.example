# =================================
# CONFIGURACIÓN DEL SISTEMA DE BIENES
# =================================

# CONFIGURACIÓN DE LA BASE DE DATOS MYSQL
# ----------------------------------------
# IMPORTANTE:
# - Si corres el backend DENTRO de Docker: usa MYSQL_HOST=mysql_db
# - Si corres el backend FUERA de Docker (local): usa MYSQL_HOST=localhost
MYSQL_HOST=mysql_db
MYSQL_PORT=3306
MYSQL_DATABASE=bienes
MYSQL_USER=bienes_user
MYSQL_PASSWORD=bienes_password
MYSQL_ROOT_PASSWORD=rootpassword

# URL COMPLETA DE CONEXIÓN (se construye automáticamente)
# DATABASE_URL=mysql+pymysql://bienes_user:bienes_password@mysql_db:3306/bienes

# CONFIGURACIÓN DEL BACKEND FASTAPI
# ----------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DEBUG=false
BACKEND_RELOAD=false

# CONFIGURACIÓN DE SEGURIDAD
# ---------------------------
SECRET_KEY=tu_clave_secreta_muy_segura_aqui
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CONFIGURACIÓN DE PHPMYADMIN
# ---------------------------
PMA_HOST=mysql_db
PMA_USER=bienes_user
PMA_PASSWORD=bienes_password

# CONFIGURACIÓN DE DESARROLLO/PRODUCCIÓN
# ---------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# CONFIGURACIÓN DE EMAILS (FUTURO)
# ---------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_email@gmail.com
# SMTP_PASSWORD=tu_password_de_app
# FROM_EMAIL=noreply@tuempresa.com

# CONFIGURACIÓN DE UPLOADS (FUTURO)
# ----------------------------------
# MAX_FILE_SIZE_MB=10
# ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx
# UPLOAD_PATH=./uploads

# CONFIGURACIÓN DE BACKUP (FUTURO)
# ---------------------------------
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_RETENTION_DAYS=30